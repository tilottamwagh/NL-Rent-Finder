# Copy this to .env for local development
# In production: set all in Coolify environment variables

DATABASE_URL=postgresql://user:password@localhost/nlrentfinder
REDIS_URL=redis://localhost:6379

AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-proj-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# GEMINI_API_KEY=your-key-here
# GROQ_API_KEY=your-key-here

TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHANNEL_IDS=-100123456789,-100987654321

SECRET_KEY=generate-a-long-random-string-here
FRONTEND_URL=https://nlrentfinder.tilottamwagh.com
API_URL=https://api.nlrentfinder.tilottamwagh.com

SCRAPE_INTERVAL_HOURS=2
SERVICE_FEE_EUR=50
PAYPAL_LINK=paypal.me/yourname
PAYPAL_NAME=Your Name
LISTING_EXPIRY_DAYS=30
